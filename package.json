  "author": "Hai",
  "license": "MIT",
  "dependencies": {
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.2.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.4.0",
    "terser": "^5.47.1",
    "ts-jest": "^29.2.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.3",
    "vite": "^5.4.0"
  }
}
