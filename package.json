{
  "name": "excel-functions-reference",
  "version": "2.0.0",
  "description": "Excel 函数大全 - 交互式参考手册 (第二阶段优化版)",
  "type": "module",
  "main": "index.html",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint js/ data/ --ext .js,.ts",
    "lint:fix": "eslint js/ data/ --ext .js,.ts --fix",
    "format": "prettier --write \"**/*.{js,ts,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,json,css,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "type-check": "tsc --noEmit",
    "rebuild": "node scripts/rebuild_final.js",
    "add-quizzes": "node scripts/add_quizzes_final.js"
  },
  "keywords": [
    "excel",
